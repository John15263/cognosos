APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cognosos

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_NORMALIZE=true

LLM_PROVIDER=mock
ALLOW_REMOTE_LLM=false

GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-3.5-flash
# Use EMBEDDING_PROVIDER=gemini and EMBEDDING_MODEL=gemini-embedding-2 to enable Gemini embeddings.

TRIGGER_HIGH_SIMILARITY=0.78
TRIGGER_MEDIUM_SIMILARITY=0.72
TRIGGER_SHORT_WINDOW_DAYS=14
TRIGGER_MEDIUM_WINDOW_DAYS=30
TRIGGER_LONG_WINDOW_DAYS=90

APP_TIMEZONE=UTC

# Markdown-first storage. Point Obsidian, VS Code, Typora, or any Markdown editor at this folder.
COGNOSOS_VAULT_PATH=./obsidian-vault-demo
COGNOSOS_DAILY_FOLDER=Calendar

# Backward-compatible aliases also work:
# MARKDOWN_VAULT_PATH=./obsidian-vault-demo
# MARKDOWN_DAILY_FOLDER=Calendar
# OBSIDIAN_VAULT_PATH=./obsidian-vault-demo
# OBSIDIAN_DAILY_FOLDER=Calendar
